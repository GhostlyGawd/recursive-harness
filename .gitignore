state/*
!state/.gitkeep
evals/results/*
!evals/results/.gitkeep
__pycache__/
*.pyc
HUMAN_APPROVED
.claude-private/
# Worktrees materialize under .claude/worktrees/<name>; never commit their
# contents (they'd surface as `?? .claude/` in the main checkout). See skills/worktree.
.claude/worktrees/
# Per-project Claude config (plugin enablement + permission allowlist). Ignored
# at the REPO level so `.worktreeinclude` copies it into worktrees on any clone,
# not just machines that happen to ignore it via a global gitignore. See skills/worktree §2.
.claude/settings.local.json
# Ventures are outputs, not the harness brain — kept on disk, not in the trunk.
# Each venture is its own repo (or untracked working dir) under products/<slug>/.
products/
