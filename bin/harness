#!/usr/bin/env python3
"""harness — state ledger CLI for the self-improving harness.

Subcommands:
  predict      Log a falsifiable prediction before acting.
  outcome      Score a prediction after the fact.
  stats        Calibration report (hit rate + Brier score by confidence bucket).
  corrections  add | count | list  — user-correction ledger.
  skill-fired  Record that a skill triggered (called by PostToolUse hook).
  skill-stats  Fire counts per skill over a window (feeds /meta-retro).
  followup     add | list | done | count — deferred-task ledger (TTL-decayed,
               so it can't rot into a guilt pile). Captured silently; pulled via /followups.
  approve      Record a human's enforcement-layer approval (verbal/remote OK) and
               place the HUMAN_APPROVED marker; --revoke removes it; --status shows it.
  retro-done   add | list | has — DURABLE ledger of retro'd sessions (persists past
               session end, unlike the ephemeral retro_gate_* flag); feeds /retro-backlog.
  gc           Roll hot state older than N days into versioned monthly summaries.
  fleet        emit | feed | reap — lateral-coordination event channel for agents
               (append-only, typed, self-reaping; resolves the one canonical state/).
  mission-control  Launch Mission Control — the read-only control-room TUI
               (python -m mission_control; needs textual). --root / --json passthrough.
  map          Regenerate the Harness Atlas (cartograph/atlas.py → ATLAS.md +
               ATLAS-PULSE.md); --html refreshes the interactive page, --check gates rot.
  health       Harness health score (0-100) from the cartograph graph; --trend for history.
  ask          Query the cartograph oracle (extract.py --query/--context): read-only
               structural Q&A (what enforces X / path A→B / dependents). See skill structural-qa.

All hot data is JSONL under state/ (machine-local, gitignored).
Rollups land in memory/calibration/ (versioned, shippable).
"""
import argparse
import datetime as dt
import json
import os
import subprocess
import sys
import uuid

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
_TREE_STATE = os.path.join(ROOT, "state")  # this script's OWN checkout (git-absent fallback)
MEMORY = os.path.join(ROOT, "memory")


def _resolve_state_dir(start=None):
    """Resolve state/ to the MAIN checkout via `git rev-parse --git-common-dir`, so a
    worktree's ledgers (predict/outcome/followup/corrections/retro-done/gc/fleet) join the
    ONE canonical log instead of a tree-local state/ that is gitignored and vanishes on
    worktree cleanup (follow-ups 1d30be + d72eec). Run git against the SCRIPT's dir (never
    cwd) for foreign-cwd safety; `start` overrides it (injectable for tests). Fall back to
    _TREE_STATE if git is absent/errors; never raises.

    Cost note: this runs ONE `git rev-parse` per CLI invocation (it sets STATE at import).
    Accepted because no hook spawns bin/harness — the hooks write state/ directly — so only
    interactive CLI calls pay it, never a hot per-tool-use loop. A git-free PATH-only fast
    path (cf. hooks/inject_kernel._repo_root) is deferred to the shared-path-util extraction
    (follow-up 3939d8): bin/ is off the hooks/ import path, so inlining _WT_RE here now would
    just duplicate it."""
    scriptdir = start or os.path.dirname(os.path.abspath(__file__))
    try:
        out = subprocess.run(
            ["git", "-C", scriptdir, "rev-parse", "--git-common-dir"],
            capture_output=True, text=True, timeout=5,
        )
        common = out.stdout.strip()
        if out.returncode == 0 and common:
            if not os.path.isabs(common):
                common = os.path.normpath(os.path.join(scriptdir, common))
            return os.path.join(os.path.dirname(common), "state")
    except (OSError, subprocess.SubprocessError):
        pass
    return _TREE_STATE


# state/ resolves to the MAIN checkout (single canonical ledger) — see _resolve_state_dir.
STATE = _resolve_state_dir()
# The MAIN-checkout root that STATE resolved into (its parent). The HUMAN_APPROVED marker
# MUST live here: guard_enforcement_layer.py checks the marker at ITS OWN hook root, which
# is the main checkout wired by absolute path (ADR 0004). Placing it at this script's own
# ROOT instead made a LINKED-WORKTREE `approve`/`--revoke` land where the guard never looks,
# so the unlock/revoke silently missed (followup a0f3b7). Derive it from STATE to reuse the
# single git resolution (no extra git call, no duplicated logic). Git-absent: STATE falls
# back to <script-root>/state, so MAIN_ROOT falls back to this script's own root too.
MAIN_ROOT = os.path.dirname(STATE)

PREDICTIONS = os.path.join(STATE, "predictions.jsonl")
CORRECTIONS = os.path.join(STATE, "corrections.jsonl")
SKILL_USAGE = os.path.join(STATE, "skill_usage.jsonl")
FOLLOWUPS = os.path.join(STATE, "followups.jsonl")
FOLLOWUP_TTL_DAYS = 30  # open follow-ups older than this drop out of the active view (decay)
APPROVALS = os.path.join(STATE, "approvals.jsonl")
# Durable retro-completion ledger: which sessions have been retro'd. PERSISTS (it is
# NOT a retro_gate_* name, so hooks/session_end.py's per-session cleanup never deletes
# it). /retro writes it; /retro-backlog reads it to skip already-mined sessions.
RETRO_LOG = os.path.join(STATE, "retro_log.jsonl")
MARKER = os.path.join(MAIN_ROOT, "HUMAN_APPROVED")

# --- feature flags (ADR 0008) -------------------------------------------------
FEATURES = os.path.join(ROOT, "features.json")
FEATURES_LOCAL = os.path.join(STATE, "features.local.json")
# Mirror of hooks/harness_features.LOCKED: keys that weaken a guard. `features set`
# refuses them, so a SOFT override can never disable a safety guard; they live only in
# the committed, enforcement-PROTECTED features.json (human-gated). Kept inline here
# because bin/ is not on the hooks/ import path.
LOCKED_FEATURES = {
    "guards.worktree_isolation.block",
    "guards.worktree_isolation.bash_scanner",
    "guards.worktree_session.block",
    "guards.worktree_session.ttl_seconds",
    "guards.trunk_lease.block",
}


def _now() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")


def _append(path: str, rec: dict) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "a", encoding="utf-8") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")


def _read(path: str) -> list:
    if not os.path.exists(path):
        return []
    out = []
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    out.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
    return out


def _write_all(path: str, recs: list) -> None:
    with open(path, "w", encoding="utf-8") as f:
        for r in recs:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")


# --- feature-flag readers (mirror hooks/harness_features; bin/ is off that path) ---
def _load_json(path: str) -> dict:
    """Plain JSON object -> dict; {} on missing/corrupt/non-object."""
    try:
        with open(path, encoding="utf-8") as f:
            d = json.load(f)
        return d if isinstance(d, dict) else {}
    except (OSError, ValueError):
        return {}


def _flatten_features(d: dict, prefix: str = "") -> dict:
    out: dict = {}
    for k, v in d.items():
        if isinstance(k, str) and k.startswith("_"):
            continue
        key = f"{prefix}{k}"
        if isinstance(v, dict):
            out.update(_flatten_features(v, key + "."))
        else:
            out[key] = v
    return out


def _feature(key: str, default):
    """Effective SOFT feature value (local over committed over caller default); a LOCKED
    key reads from the committed file only. Fail-safe -> default; never raises."""
    try:
        defaults = _flatten_features(_load_json(FEATURES))
        if key in LOCKED_FEATURES:
            return defaults.get(key, default)
        loc = _flatten_features(_load_json(FEATURES_LOCAL))
        return loc.get(key, defaults.get(key, default))
    except Exception:
        return default


def _coerce_feature(raw: str):
    """Parse a CLI value string into bool / int / float / None / str."""
    low = raw.strip().lower()
    if low in ("true", "false"):
        return low == "true"
    if low in ("null", "none"):
        return None
    try:
        return float(raw) if "." in raw else int(raw)
    except ValueError:
        return raw


# (_resolve_state_dir moved above, beside STATE, so every ledger constant derives from it)


# ---------------------------------------------------------------- predict
def cmd_predict(args) -> int:
    pid = uuid.uuid4().hex[:8]
    rec = {
        "id": pid,
        "ts": _now(),
        "task": args.task,
        "expect": args.expect,
        "confidence": max(0.0, min(1.0, args.confidence)),
        "category": args.category,
        "result": None,
    }
    _append(PREDICTIONS, rec)
    print(f"prediction logged: {pid}  (score it later: harness outcome {pid} --result hit|miss)")
    return 0


def cmd_outcome(args) -> int:
    recs = _read(PREDICTIONS)
    found = False
    for r in recs:
        if r.get("id") == args.id:
            r["result"] = args.result
            r["scored_ts"] = _now()
            if args.notes:
                r["notes"] = args.notes
            found = True
            break
    if not found:
        print(f"no prediction with id {args.id}", file=sys.stderr)
        return 1
    _write_all(PREDICTIONS, recs)
    print(f"scored {args.id}: {args.result}")
    return 0


def _brier(recs: list) -> float:
    """Mean squared error of confidence vs. binary outcome. 0 = oracle, 0.25 = coin flip."""
    scored = [(r["confidence"], 1.0 if r["result"] == "hit" else 0.0)
              for r in recs if r.get("result") in ("hit", "miss")]
    if not scored:
        return float("nan")
    return sum((c - o) ** 2 for c, o in scored) / len(scored)


def cmd_stats(args) -> int:
    recs = _read(PREDICTIONS)
    scored = [r for r in recs if r.get("result") in ("hit", "miss")]
    pending = [r for r in recs if r.get("result") is None]
    if not scored:
        print("no scored predictions yet — calibration unknown, not good.")
        if pending:
            print(f"{len(pending)} pending; score them: harness outcome <id> --result hit|miss")
        return 0
    hits = sum(1 for r in scored if r["result"] == "hit")
    print(f"scored: {len(scored)}  hit-rate: {hits / len(scored):.0%}  brier: {_brier(scored):.3f}"
          f"  pending: {len(pending)}")
    buckets = {"low <0.6": [], "mid 0.6-0.85": [], "high >0.85": []}
    for r in scored:
        c = r["confidence"]
        key = "low <0.6" if c < 0.6 else ("mid 0.6-0.85" if c <= 0.85 else "high >0.85")
        buckets[key].append(r)
    for name, rs in buckets.items():
        if rs:
            hr = sum(1 for r in rs if r["result"] == "hit") / len(rs)
            avg_c = sum(r["confidence"] for r in rs) / len(rs)
            drift = hr - avg_c
            flag = "  <-- OVERCONFIDENT" if drift < -0.15 else ("  <-- underconfident" if drift > 0.15 else "")
            print(f"  {name:14s} n={len(rs):<3d} claimed {avg_c:.0%} actual {hr:.0%}{flag}")
    cats = {}
    for r in scored:
        cats.setdefault(r.get("category") or "general", []).append(r)
    for cat, rs in sorted(cats.items()):
        hr = sum(1 for r in rs if r["result"] == "hit") / len(rs)
        print(f"  category {cat:12s} n={len(rs):<3d} hit {hr:.0%}")
    return 0


# ------------------------------------------------------------ corrections
def cmd_corrections(args) -> int:
    if args.action == "add":
        _append(CORRECTIONS, {"ts": _now(), "session": args.session or os.environ.get("CLAUDE_SESSION_ID", "manual"),
                              "note": args.note or "", "source": "manual"})
        print("correction logged.")
    elif args.action == "count":
        recs = _read(CORRECTIONS)
        if args.session:
            recs = [r for r in recs if r.get("session") == args.session]
        print(len(recs))
    else:  # list
        for r in _read(CORRECTIONS)[-(args.last or 20):]:
            print(f"{r['ts']}  [{r.get('session', '?')[:8]}]  {r.get('note', r.get('snippet', ''))[:120]}")
    return 0


# ------------------------------------------------------------ skill usage
def cmd_skill_fired(args) -> int:
    _append(SKILL_USAGE, {"ts": _now(), "skill": args.name,
                          "session": args.session or os.environ.get("CLAUDE_SESSION_ID", "?")})
    return 0


def cmd_skill_stats(args) -> int:
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=args.days)
    counts: dict = {}
    for r in _read(SKILL_USAGE):
        try:
            ts = dt.datetime.fromisoformat(r["ts"])
        except (KeyError, ValueError):
            continue
        if ts >= cutoff:
            counts[r["skill"]] = counts.get(r["skill"], 0) + 1
    skills_dir = os.path.join(ROOT, "skills")
    installed = sorted(os.listdir(skills_dir)) if os.path.isdir(skills_dir) else []
    for s in installed:
        n = counts.get(s, 0)
        flag = "  <-- ZERO FIRES, prune candidate" if n == 0 else ""
        print(f"{s:24s} fired {n:4d}x in {args.days}d{flag}")
    for s, n in sorted(counts.items()):
        if s not in installed:
            print(f"{s:24s} fired {n:4d}x  (not in skills/ — project skill? promote or ignore)")
    return 0


# -------------------------------------------------------------------- gc
def cmd_gc(args) -> int:
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=args.days)
    moved = 0
    for path, kind in ((PREDICTIONS, "predictions"), (CORRECTIONS, "corrections"), (SKILL_USAGE, "skill_usage")):
        recs = _read(path)
        hot, cold = [], {}
        for r in recs:
            try:
                ts = dt.datetime.fromisoformat(r["ts"])
            except (KeyError, ValueError):
                hot.append(r)
                continue
            if ts >= cutoff or (kind == "predictions" and r.get("result") is None):
                hot.append(r)  # never archive unscored predictions silently
            else:
                cold.setdefault(ts.strftime("%Y-%m"), []).append(r)
        for month, rs in cold.items():
            summary_path = os.path.join(MEMORY, "calibration", f"{month}.json")
            existing = {}
            if os.path.exists(summary_path):
                with open(summary_path, encoding="utf-8") as f:
                    existing = json.load(f)
            bucket = existing.setdefault(kind, {"n": 0})
            bucket["n"] += len(rs)
            if kind == "predictions":
                scored = [r for r in rs if r.get("result") in ("hit", "miss")]
                if scored:
                    prev_n = bucket.get("scored", 0)
                    prev_hits = round(bucket.get("hit_rate", 0.0) * prev_n)
                    new_hits = prev_hits + sum(1 for r in scored if r["result"] == "hit")
                    bucket["scored"] = prev_n + len(scored)
                    bucket["hit_rate"] = round(new_hits / bucket["scored"], 3)
                    bucket["brier"] = round(_brier(scored), 3)
            os.makedirs(os.path.dirname(summary_path), exist_ok=True)
            with open(summary_path, "w", encoding="utf-8") as f:
                json.dump(existing, f, indent=2)
            moved += len(rs)
        _write_all(path, hot)
    print(f"gc: rolled {moved} cold records into memory/calibration/ monthly summaries.")
    print("reminder: also run the user-model decay pass described in commands/gc.md.")
    return 0


# ------------------------------------------------------------- followups
def _followup_active(r: dict, cutoff: dt.datetime) -> bool:
    """Open AND not past its TTL. Unparseable timestamps stay visible (never silently dropped)."""
    if r.get("status") != "open":
        return False
    try:
        return dt.datetime.fromisoformat(r["ts"]) >= cutoff
    except (KeyError, ValueError):
        return True


def cmd_followup(args) -> int:
    # SOFT flag (ADR 0008): the decay window is tunable; FOLLOWUP_TTL_DAYS is the default.
    ttl_days = _feature("workflow.followup_ttl_days", FOLLOWUP_TTL_DAYS)
    try:
        ttl_days = float(ttl_days)
        if ttl_days <= 0:
            ttl_days = FOLLOWUP_TTL_DAYS
    except (TypeError, ValueError):
        ttl_days = FOLLOWUP_TTL_DAYS
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=ttl_days)
    if args.action == "add":
        if not args.arg.strip():
            print("nothing to log (give the follow-up text)", file=sys.stderr)
            return 1
        fid = uuid.uuid4().hex[:6]
        _append(FOLLOWUPS, {"id": fid, "ts": _now(), "text": args.arg.strip(),
                            "task": args.task or os.environ.get("CLAUDE_SESSION_ID", ""),
                            "status": "open"})
        print(f"follow-up logged: {fid}")
        return 0

    recs = _read(FOLLOWUPS)
    if args.action == "count":
        print(sum(1 for r in recs if _followup_active(r, cutoff)))
        return 0
    if args.action == "done":
        note = (args.note or "").strip()
        folded = (getattr(args, "folded_into", "") or "").strip()
        for r in recs:
            if r.get("id") == args.arg:
                r["status"] = "done"
                r["done_ts"] = _now()
                # Record the close reason / fold trail IN the ledger so an applied
                # synthesis fold is traceable from `--all`, not only the PR/chat (254593).
                if note:
                    r["note"] = note
                if folded:
                    r["folded_into"] = folded
                _write_all(FOLLOWUPS, recs)
                trail = f" (folded -> {folded})" if folded else (f" ({note})" if note else "")
                print(f"follow-up {args.arg} marked done{trail}")
                return 0
        print(f"no follow-up with id {args.arg}", file=sys.stderr)
        return 1
    # list
    shown = recs if args.all else [r for r in recs if _followup_active(r, cutoff)]
    if not shown:
        print("no follow-ups." if args.all else "no open follow-ups (clean slate).")
        return 0
    for r in shown:
        st = r.get("status", "open")
        try:
            stale = st == "open" and dt.datetime.fromisoformat(r["ts"]) < cutoff
        except (KeyError, ValueError):
            stale = False
        mark = "done " if st == "done" else ("stale" if stale else "open ")
        line = f"  [{r.get('id', '?')}] {mark} {r.get('ts', '')[:10]}  {r.get('text', '')[:100]}"
        if st == "done":
            if r.get("folded_into"):
                line += f"  (folded -> {r['folded_into']})"
            elif r.get("note"):
                line += f"  ({r['note'][:60]})"
        print(line)
    return 0


# ------------------------------------------------------------- retro-done
# provenance: session 9856a41f, 2026-06-19 — added a DURABLE retro-completion ledger.
# A forensic sweep (workflow wf_8058e958) found the harness had NO persistent record of
# which sessions were retro'd: the only marker, state/retro_gate_<id>, is an ephemeral
# Stop-nudge flag that hooks/session_end.py deletes at session end. So /retro could not be
# swept over a backlog. This ledger persists; /retro-backlog reads it to skip done sessions.
def cmd_retro_done(args) -> int:
    """Durable ledger of sessions that have been retro'd (state/retro_log.jsonl).

    Unlike the ephemeral state/retro_gate_<id> Stop-nudge flag (deleted by
    hooks/session_end.py at session end), this PERSISTS so /retro-backlog can skip
    sessions already mined. `add` is idempotent on session_id.
    """
    recs = _read(RETRO_LOG)
    sid = (args.arg or "").strip()
    if args.action == "list":
        if not recs:
            print("(no sessions recorded as retro'd yet)", file=sys.stderr)
            return 0
        for r in recs:
            print(f"{r.get('session_id', '?')}\t{r.get('ts', '')[:10]}\t{r.get('slug', '')}")
        return 0
    if args.action == "has":
        if not sid:
            print("retro-done has needs a <session_id>", file=sys.stderr)
            return 1
        if any(r.get("session_id") == sid for r in recs):
            print("retro'd")
            return 0
        print("not retro'd")
        return 1
    # add (idempotent)
    if not sid:
        print("retro-done add needs a <session_id>", file=sys.stderr)
        return 1
    if any(r.get("session_id") == sid for r in recs):
        print(f"already recorded: {sid}")
        return 0
    _append(RETRO_LOG, {"session_id": sid, "slug": (args.slug or "").strip(), "ts": _now()})
    print(f"recorded retro'd session: {sid}")
    return 0


# ------------------------------------------------------------- approve
# provenance: session 9147f304, 2026-06-14 — added so a remote/voice human can grant
# enforcement-layer approval without a shell `touch`; logs the verbatim grant for audit.
def cmd_approve(args) -> int:
    """Record a human enforcement-layer approval and place/remove the marker.

    The marker only UNLOCKS drafting an enforcement-layer edit on a branch; the
    binding gate stays the PR merge (a human action). This command exists so a
    REMOTE/voice human can grant that unlock without a shell: the agent runs it
    ONLY on an explicit, unambiguous human grant, recording the grant verbatim.
    Fabricating a grant here is the same betrayal as hand-touching the marker —
    the audit trail (state/approvals.jsonl) is what makes it checkable.
    """
    # Transparency (followup a0f3b7): when run from a linked worktree the marker is
    # resolved to the MAIN checkout root (where the guard checks it, ADR 0004), NOT this
    # worktree. Surface that on a root mismatch so the human sees where it actually lands.
    if os.path.realpath(MAIN_ROOT) != os.path.realpath(ROOT):
        print(f"note: HUMAN_APPROVED marker resolves to the main checkout root "
              f"({MAIN_ROOT}), not this worktree ({ROOT}) — that is where the guard checks it.",
              file=sys.stderr)
    if args.status:
        present = os.path.exists(MARKER)
        recs = _read(APPROVALS)
        print(f"HUMAN_APPROVED marker: {'PRESENT' if present else 'absent'}")
        if recs:
            last = recs[-1]
            print(f"last log: {last.get('ts')} [{last.get('action')}] scope={last.get('scope')!r} "
                  f"grant={last.get('grant')!r}")
        return 0
    if args.revoke:
        existed = os.path.exists(MARKER)
        if existed:
            os.remove(MARKER)
        _append(APPROVALS, {"ts": _now(), "action": "revoke", "scope": args.scope or "",
                            "grant": "", "session": args.session or os.environ.get("CLAUDE_SESSION_ID", "remote")})
        print("HUMAN_APPROVED removed — guard re-locked." if existed else "no marker present; logged revoke.")
        return 0
    # grant
    if not (args.scope or "").strip() or not (args.grant or "").strip():
        print("approve needs BOTH --scope and --grant (the human's verbatim words). "
              "Refusing to create the marker without a recorded grant.", file=sys.stderr)
        return 1
    _append(APPROVALS, {"ts": _now(), "action": "grant", "scope": args.scope.strip(),
                        "grant": args.grant.strip(),
                        "session": args.session or os.environ.get("CLAUDE_SESSION_ID", "remote")})
    with open(MARKER, "w", encoding="utf-8") as f:
        f.write(f"approved: {args.scope.strip()}\ngrant: {args.grant.strip()}\nlogged: {_now()}\n")
    print(f"HUMAN_APPROVED placed for scope {args.scope.strip()!r} (grant logged to state/approvals.jsonl).")
    print("Make ONLY the approved edit, then run: harness approve --revoke")
    return 0


# ------------------------------------------------------------- features
# provenance: 2026-06-18, session 44bdfc6f — view/set harness feature flags (ADR 0008).
def cmd_features(args) -> int:
    """View or set harness feature flags. SOFT keys write to state/features.local.json;
    LOCKED safety keys are read-only here (edit the committed features.json by hand)."""
    action = args.action or "list"
    defaults = _flatten_features(_load_json(FEATURES))
    if not defaults:
        print(f"no features.json found at {FEATURES} — nothing to configure.", file=sys.stderr)
        return 1
    local = _load_json(FEATURES_LOCAL)
    flat_local = _flatten_features(local)

    if action == "list":
        for k in sorted(defaults):
            if k in LOCKED_FEATURES:
                val, src, note = defaults[k], "locked", "  [edit features.json]"
            elif k in flat_local:
                val, src, note = flat_local[k], "local", ""
            else:
                val, src, note = defaults[k], "default", ""
            print(f"  {k:46s} {json.dumps(val):>10}  ({src}){note}")
        return 0

    if action == "get":
        if not args.key:
            print("usage: harness features get <key>", file=sys.stderr)
            return 1
        print(json.dumps(_feature(args.key, None)))
        return 0

    if action == "set":
        if not args.key or args.value == "":
            print("usage: harness features set <key> <value>", file=sys.stderr)
            return 1
        if args.key in LOCKED_FEATURES:
            print(f"'{args.key}' is a LOCKED safety key -- set it in the committed "
                  f"features.json (human-gated), not the local override. See ADR 0008.",
                  file=sys.stderr)
            return 1
        if args.key not in defaults:
            print(f"unknown feature key '{args.key}'. Run `harness features` to list keys.",
                  file=sys.stderr)
            return 1
        local[args.key] = _coerce_feature(args.value)  # stored flat; the reader flattens both
        os.makedirs(os.path.dirname(FEATURES_LOCAL), exist_ok=True)
        with open(FEATURES_LOCAL, "w", encoding="utf-8") as f:
            json.dump(local, f, indent=2)
            f.write("\n")
        print(f"set {args.key} = {json.dumps(local[args.key])}  "
              f"(local override -> state/features.local.json)")
        return 0

    if action == "unset":
        if not args.key:
            print("usage: harness features unset <key>", file=sys.stderr)
            return 1
        if args.key in local:
            del local[args.key]
            with open(FEATURES_LOCAL, "w", encoding="utf-8") as f:
                json.dump(local, f, indent=2)
                f.write("\n")
            print(f"unset {args.key} (reverted to committed default)")
        else:
            print(f"{args.key} had no local override.")
        return 0

    print(f"unknown action {action!r} (list|get|set|unset)", file=sys.stderr)
    return 1


# ---------------------------------------------------------------- fleet
def cmd_fleet(args) -> int:
    """Agent Mail — the lateral-coordination channel. Thin adapter: inject the ONE canonical
    state dir, then delegate the full action surface (feed|emit|claims|unit|send|inbox|ack|
    release|reap) to the unlocked, stdlib-only fleet.cli. Adding a view needs no further edit
    here. See proposals/2026-06-30-agent-mail-bin-delegation.md + fleet/pm/specs/ARCHITECTURE.md."""
    sys.path.insert(0, ROOT)  # fleet/ lives at the repo root
    try:
        from fleet import cli as fleet_cli
    except ImportError as exc:
        print(f"fleet engine unavailable: {exc}", file=sys.stderr)
        return 1
    return fleet_cli.main(["--state-dir", _resolve_state_dir(), *args.rest])


# ---------------------------------------------------------------- mission control
def _mission_control_dispatch(args, root, launcher=None):
    """Dispatch `harness mission-control` -> mission_control.__main__.main(argv). `root` is where the
    mission_control package lives (ROOT); `launcher` is injected only by tests. --root and --json are
    mutually exclusive at the TUI layer, so pass at most one (root wins if both are given)."""
    if launcher is None:
        sys.path.insert(0, root)
        try:
            from mission_control.__main__ import main as launcher
        except ImportError as exc:
            print(f"mission_control unavailable (is textual installed?): {exc}", file=sys.stderr)
            return 1
    argv = []
    if getattr(args, "root", ""):
        argv += ["--root", args.root]
    elif getattr(args, "json", ""):
        argv += ["--json", args.json]
    return launcher(argv)


def cmd_mission_control(args) -> int:
    """Launch Mission Control — the read-only control-room TUI (python -m mission_control)."""
    return _mission_control_dispatch(args, ROOT)


def cmd_map(args) -> int:
    """Regenerate the Harness Atlas: a thin, discoverable front door over the cartograph
    scripts (they stay the source of truth — this only shells out to them, never
    re-implements the render). Default: write cartograph/ATLAS.md + ATLAS-PULSE.md via
    atlas.py. --check runs the structural-rot gate FIRST (so a rotted graph is caught
    before the map is rebuilt over it); --html also refreshes the interactive page."""
    atlas_py = os.path.join(ROOT, "cartograph", "atlas.py")
    extract_py = os.path.join(ROOT, "cartograph", "extract.py")
    if not os.path.isfile(atlas_py):
        sys.stderr.write("harness map: cartograph/atlas.py not found\n")
        return 1
    rc = 0
    if args.check:
        rc = subprocess.run([sys.executable, extract_py, "--check"]).returncode or rc
    rc = subprocess.run([sys.executable, atlas_py]).returncode or rc
    if args.html:
        rc = subprocess.run(
            [sys.executable, extract_py, "--html",
             os.path.join(ROOT, "cartograph", "index.html")]).returncode or rc
    return rc


def cmd_health(args) -> int:
    """Harness health score: a thin front door over cartograph/health.py (which stays the
    source of truth — this only shells out, never re-implements the metric). Prints the
    0-100 score + sub-scores; --trend [N] adds the score at the last N commits; --json
    for machines."""
    health_py = os.path.join(ROOT, "cartograph", "health.py")
    if not os.path.isfile(health_py):
        sys.stderr.write("harness health: cartograph/health.py not found\n")
        return 1
    cmd = [sys.executable, health_py]
    if args.trend is not None:
        cmd += ["--trend", str(args.trend)]
    if args.json:
        cmd.append("--json")
    return subprocess.run(cmd).returncode


def cmd_ask(args) -> int:
    """Query the cartograph oracle: a thin front door over cartograph/extract.py --query /
    --context (read-only structural Q&A; the engine stays source of truth). `ask <kind>
    [target...]` forwards to --query; `ask --context <node>` to --context. See skill
    structural-qa for the question→kind mapping."""
    extract_py = os.path.join(ROOT, "cartograph", "extract.py")
    if not args.rest:
        sys.stderr.write("harness ask: need a query — e.g. `ask path A B`, `ask dependents "
                         "<node>`, `ask --context <node>` (kinds: blast-radius|dependents|"
                         "dependencies|path|orphans|node|governed-by|traces)\n")
        return 2
    flag = "--context" if args.context else "--query"
    cmd = [sys.executable, extract_py, flag] + list(args.rest)
    if args.json:
        cmd.append("--json")
    return subprocess.run(cmd).returncode


def main() -> int:
    # cp1252 consoles (Windows) crash when a subcommand echoes a non-latin1 char
    # (e.g. an arrow in a correction note) - degrade unencodable output to '?'
    # instead of dying mid-write, as skills/auto-healer/heal.py already does. (bug 1860a068)
    for _s in (sys.stdout, sys.stderr):
        try:
            _s.reconfigure(encoding="utf-8", errors="replace")
        except (AttributeError, ValueError):
            pass
    p = argparse.ArgumentParser(prog="harness", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("predict")
    sp.add_argument("--task", required=True)
    sp.add_argument("--expect", required=True, help="falsifiable expected outcome")
    sp.add_argument("--confidence", type=float, required=True)
    sp.add_argument("--category", default="general")
    sp.set_defaults(fn=cmd_predict)

    sp = sub.add_parser("outcome")
    sp.add_argument("id")
    sp.add_argument("--result", choices=["hit", "miss"], required=True)
    sp.add_argument("--notes", default="")
    sp.set_defaults(fn=cmd_outcome)

    sp = sub.add_parser("stats")
    sp.set_defaults(fn=cmd_stats)

    sp = sub.add_parser("corrections")
    sp.add_argument("action", choices=["add", "count", "list"])
    sp.add_argument("--note", default="")
    sp.add_argument("--session", default="")
    sp.add_argument("--last", type=int, default=20)
    sp.set_defaults(fn=cmd_corrections)

    sp = sub.add_parser("skill-fired")
    sp.add_argument("name")
    sp.add_argument("--session", default="")
    sp.set_defaults(fn=cmd_skill_fired)

    sp = sub.add_parser("skill-stats")
    sp.add_argument("--days", type=int, default=30)
    sp.set_defaults(fn=cmd_skill_stats)

    sp = sub.add_parser("followup")
    sp.add_argument("action", choices=["add", "list", "done", "count"])
    sp.add_argument("arg", nargs="?", default="", help="text (for add) or id (for done)")
    sp.add_argument("--task", default="")
    sp.add_argument("--all", action="store_true", help="include done + stale entries")
    sp.add_argument("--note", default="",
                    help="on `done`: a closing note recorded IN the ledger (e.g. why dropped)")
    sp.add_argument("--folded-into", default="",
                    help="on `done`: the root-cause id this symptom folded into; records the "
                         "fold trail in the ledger so /followups reconcile stays traceable")
    sp.set_defaults(fn=cmd_followup)

    sp = sub.add_parser("retro-done", help="durable ledger of retro'd sessions (feeds /retro-backlog)")
    sp.add_argument("action", choices=["add", "list", "has"])
    sp.add_argument("arg", nargs="?", default="", help="session_id (for add/has)")
    sp.add_argument("--slug", default="", help="the retro slug, for context")
    sp.set_defaults(fn=cmd_retro_done)

    sp = sub.add_parser("approve")
    sp.add_argument("--scope", default="", help="what the edit is (e.g. 'autonomy ledger reconciliation')")
    sp.add_argument("--grant", default="", help="the human's verbatim approving words")
    sp.add_argument("--session", default="")
    sp.add_argument("--revoke", action="store_true", help="remove the marker, re-lock the guard")
    sp.add_argument("--status", action="store_true", help="show marker state + last grant")
    sp.set_defaults(fn=cmd_approve)

    sp = sub.add_parser("gc")
    sp.add_argument("--days", type=int, default=30)
    sp.set_defaults(fn=cmd_gc)

    sp = sub.add_parser("features", help="view/set harness feature flags (ADR 0008)")
    sp.add_argument("action", nargs="?", default="list",
                    choices=["list", "get", "set", "unset"])
    sp.add_argument("key", nargs="?", default="")
    sp.add_argument("value", nargs="?", default="")
    sp.set_defaults(fn=cmd_features)

    sp = sub.add_parser("fleet",
                        help="Agent Mail — coordination channel (feed|emit|claims|unit|send|inbox|ack|release|reap)")
    sp.add_argument("rest", nargs=argparse.REMAINDER,
                    help="forwarded verbatim to `python -m fleet` (run `harness fleet --help` for actions)")
    sp.set_defaults(fn=cmd_fleet)

    sp = sub.add_parser("mission-control",
                        help="launch the read-only control-room TUI (Mission Control)")
    sp.add_argument("--root", default="",
                    help="harness root to read --mission from (default: this tree)")
    sp.add_argument("--json", default="", help="render a saved --mission payload (offline/demo)")
    sp.set_defaults(fn=cmd_mission_control)

    sp = sub.add_parser("map", help="regenerate the Harness Atlas (ATLAS.md + ATLAS-PULSE.md)")
    sp.add_argument("--html", action="store_true",
                    help="also refresh the interactive cartograph page (needs vendor/*.js)")
    sp.add_argument("--check", action="store_true",
                    help="run the structural-rot gate before regenerating")
    sp.set_defaults(fn=cmd_map)

    sp = sub.add_parser("health",
                        help="harness health score (0-100) from the cartograph graph; --trend for history")
    sp.add_argument("--trend", nargs="?", const=6, type=int, default=None, metavar="N",
                    help="also score the last N first-parent commits (default 6; heavier)")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_health)

    sp = sub.add_parser("ask",
                        help="query the cartograph oracle (extract.py --query/--context): read-only structural Q&A")
    sp.add_argument("--context", action="store_true",
                    help="node-brief mode (--context <node>) instead of --query")
    sp.add_argument("--json", action="store_true")
    sp.add_argument("rest", nargs=argparse.REMAINDER,
                    help="KIND [TARGET...] for --query, or <node> with --context")
    sp.set_defaults(fn=cmd_ask)

    args = p.parse_args()
    return args.fn(args)


if __name__ == "__main__":
    sys.exit(main())
