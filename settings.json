{
  "hooks": {
    "SessionStart": [
      {"matcher": "startup|resume|clear",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/session_start.py"}]},
      {"matcher": "resume|clear",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/guard_worktree_session.py"}]}
    ],
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/log_correction.py"}]}
    ],
    "PreToolUse": [
      {"matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/guard_enforcement_layer.py"}]},
      {"matcher": "Read|Glob|Grep|Edit|Write|MultiEdit|NotebookEdit|Bash",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/guard_worktree_isolation.py"}]},
      {"matcher": "Read|Glob|Grep|Edit|Write|MultiEdit|NotebookEdit|Bash",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/guard_worktree_session.py"}]}
    ],
    "PostToolUse": [
      {"matcher": "Skill",
       "hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/log_skill_use.py"}]}
    ],
    "Stop": [
      {"hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/stop_retro_gate.py"}]}
    ],
    "SessionEnd": [
      {"hooks": [{"type": "command", "command": "python3 ~/.claude/hooks/session_end.py"},
                 {"type": "command", "command": "python3 ~/.claude/hooks/guard_worktree_session.py"}]}
    ]
  }
}
